# Copy to .env for local development. Do not commit real secrets.

DOMAIN=localhost
SERVER_NAME=localhost
SERVER_HOST=http://localhost
SERVER_PORT=80
BACKEND_CORS_ORIGINS=["http://localhost:3001","http://localhost:8080"]
PROJECT_NAME=5G Network Optimization
USERS_OPEN_REGISTRATION=false
USE_PUBLIC_KEY_VERIFICATION=false
PRODUCTION=false
DOMAIN_NAME=localhost

SECRET_KEY=change-me-to-a-long-random-secret
JWT_SECRET=change-me-to-a-different-long-random-secret
JWT_REFRESH_SECRET=change-me-to-a-third-long-random-secret

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-me
SENTRY_DSN=

POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app
PGADMIN_LISTEN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me

MONGO_USER=root
MONGO_PASSWORD=change-me
MONGO_CLIENT=mongodb://root:change-me@mongo_nef:27017
MONGO_EXPRESS_ENABLE_ADMIN=false

NEF_SCHEME=http
NEF_HOST=localhost
NEF_PORT=8080
NEF_URL=http://localhost:8080
NEF_API_URL=http://nef-emulator:80
NEF_USERNAME=admin@example.com
NEF_PASSWORD=change-me

AUTH_USERNAME=ml-admin
AUTH_PASSWORD=change-me
AUTH_ROLES=admin,predict,train,nef,data
ML_BASE_URL=http://localhost:5050
ML_URL=http://localhost:5050
ML_SERVICE_USERNAME=ml-admin
ML_SERVICE_PASSWORD=change-me
# High enough for internal NEF-to-ML prediction traffic during controlled experiments.
RATELIMIT_PREDICT=3000 per minute
# High enough for internal NEF-to-ML QoS feedback during controlled experiments.
# Keep this explicit so rate limiting remains visible and configurable.
RATELIMIT_FEEDBACK=3000 per minute
PROMETHEUS_URL=http://localhost:9090

METRICS_AUTH_USERNAME=metrics
METRICS_AUTH_PASSWORD=change-me
METRICS_API_KEY=change-me
GF_SECURITY_ADMIN_PASSWORD=change-me

COMPOSE_PROFILES=ml
ML_LOCAL=0
ML_HANDOVER_ENABLED=1
ML_SERVICE_URL=http://ml-service:5050
# Final thesis evidence must use an explicit pretrained model artifact.
# Leave these disabled for local development; enable them for final runs only.
# ML_MODEL_HOST_DIR is mounted read-only at /app/final-models in ml-service.
ML_MODEL_HOST_DIR=./services/ml-service/ml_service/app/models
MODEL_PATH=
MODEL_PATH_HOST=
FEATURE_CONFIG_PATH=
FEATURE_CONFIG_PATH_HOST=
THESIS_FINAL_RUN=0
REQUIRE_PRETRAINED_MODEL=0
DISABLE_SYNTHETIC_MODEL_BOOTSTRAP=0
HANDOVER_BASELINE_SERVICE_PATH=/opt/handover-baseline-service
# Required only for live tuned_a3_baseline mode. Point to a real tuning JSON
# generated from calibration traces; do not invent tuned parameters.
TUNED_A3_CONFIG_PATH=
NGINX_API_UPSTREAM=http://nef-emulator:80

CAPIF_HOST=capif
CAPIF_HTTP_PORT=8080
CAPIF_HTTPS_PORT=443
EXTERNAL_NET=false

DOCKER_IMAGE_BACKEND=5g-network-optimization/nef-emulator
BACKEND_TAG=latest
DOCKER_IMAGE_FRONTEND=5g-network-optimization/kinisis-ui
DOCKER_IMAGE_PROXY=nginx
PROXY_TAG=latest
NGINX_HTTP=8080
NGINX_HTTPS=4443
NGINX_HOST=localhost
